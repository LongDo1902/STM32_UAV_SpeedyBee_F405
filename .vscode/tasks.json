{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build STM32 project",
            "type": "shell",
            "command": "${env:STM32_MAKE_EXE}",
            "args": [
                "-j20",
                "all"
            ],
            "options": {
                "cwd": "${workspaceFolder}\\Debug",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                },
                "env": {
                    "PATH": "${env:STM32_GCC_BIN};${env:Path}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}